# EngramR environment variables
# Copy to .env and fill in values as needed: cp .env.example .env
# See _code/README.md for full details on each variable.

# -- Obsidian Local REST API (optional) --
# OBSIDIAN_API_KEY=
# OBSIDIAN_API_URL=https://127.0.0.1:27124

# -- Literature search backends (optional, biomedical domains) --
# NCBI_API_KEY=
# NCBI_EMAIL=
# S2_API_KEY=
# OPENALEX_API_KEY=
# LITERATURE_ENRICHMENT_EMAIL=

# -- Vault path (optional, for daemon/decision engine/registry) --
# VAULT_PATH=

# -- Slack integration (all required if using Slack) --
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_BOT_CHANNEL=
# SLACK_DEFAULT_CHANNEL=
# SLACK_TEAM_ID=
# ANTHROPIC_API_KEY=
