---
const base = import.meta.env.BASE_URL;

const columns = [
  {
    title: "Product",
    links: [
      { label: "Docs", url: `${base}docs/` },
      { label: "About", url: `${base}about/` },
      { label: "GitHub", url: "https://github.com/achousal/EngramR" },
    ],
  },
  {
    title: "Ecosystem",
    links: [
      { label: "Ars Contexta", url: "https://github.com/agenticnotetaking/arscontexta" },
      { label: "Claude Code", url: "https://docs.anthropic.com/en/docs/claude-code" },
      { label: "Obsidian", url: "https://obsidian.md/" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "Discussions", url: "https://github.com/achousal/EngramR/discussions" },
      { label: "Issues", url: "https://github.com/achousal/EngramR/issues" },
    ],
  },
];
---

<footer class="py-16 border-t border-border">
  <div class="max-w-4xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-start gap-10 mb-12">
      <div>
        <span class="font-display text-xl font-semibold">
          Engram<span class="text-accent">R</span>
        </span>
        <p class="mt-2 text-sm text-text-muted">MIT License</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 md:gap-12">
        {columns.map((col) => (
          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">
              {col.title}
            </h4>
            <ul class="space-y-2">
              {col.links.map((link) => (
                <li>
                  <a href={link.url} class="text-sm text-text-muted hover:text-text transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-6 border-t border-border">
      <p class="text-sm text-text-muted italic leading-relaxed max-w-xl">
        The reactor is running. The question is which ideas to put into it.
      </p>
      <p class="text-xs text-text-muted">
        Built with Astro + Tailwind
      </p>
    </div>
  </div>
</footer>
