---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import Nav from "@components/Nav.astro";
import "@styles/global.css";

const docs = await getCollection("docs");
const base = import.meta.env.BASE_URL;

const tiers = [
  {
    label: "Core",
    description:
      "The 5 pages everyone reads. They form a dependency chain -- start at Getting Started and work through.",
    slugs: ["getting-started", "skills", "workflows", "architecture", "configuration"],
  },
  {
    label: "Reference",
    description:
      "Standalone deep-dives. No reading order between them -- pull one off the shelf when you need it.",
    slugs: ["literature", "plotting", "querying", "meta-skills"],
  },
  {
    label: "Operations",
    description:
      "Running the system in production. These assume you have read the core tier.",
    slugs: ["integrations", "administration", "security", "inter-lab", "troubleshooting"],
  },
];

const routes = [
  { need: "Search PubMed, arXiv, Semantic Scholar", slug: "literature" },
  { need: "Publication-quality figures", slug: "plotting" },
  { need: "Slack, Obsidian, MCP servers, daemon", slug: "integrations" },
  { need: "Autonomous daemon, hooks, scripts", slug: "administration" },
  { need: "Multi-lab federation", slug: "inter-lab" },
  { need: "Write validation, tamper detection, PII", slug: "security" },
  { need: "ripgrep query patterns", slug: "querying" },
  { need: "/ask, /architect, /rethink, /remember", slug: "meta-skills" },
  { need: "Diagnosing problems", slug: "troubleshooting" },
];

function findDoc(slug: string) {
  return docs.find((d) => d.id === slug);
}

function titleFromSlug(slug: string): string {
  const doc = findDoc(slug);
  if (doc?.data.title) return doc.data.title;
  return slug.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
}

function descFromSlug(slug: string): string {
  const doc = findDoc(slug);
  return doc?.data.description || "";
}

function readingTime(slug: string): string {
  const doc = findDoc(slug);
  if (!doc?.body) return "";
  const words = doc.body.trim().split(/\s+/).length;
  const minutes = Math.max(1, Math.ceil(words / 200));
  return `${minutes} min read`;
}

// Build search data for client-side filtering
const searchData = [...new Set(tiers.flatMap((t) => t.slugs))].map((slug) => ({
  slug,
  title: titleFromSlug(slug),
  description: descFromSlug(slug),
}));
---

<Base title="Documentation -- EngramR">
  <Nav />
  <div class="max-w-5xl mx-auto px-6 pt-20 pb-16">
    <div class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold font-display mb-4">Documentation</h1>
      <p class="text-text-muted text-lg max-w-2xl mb-6">
        Two ways in: follow the reading order to learn sequentially, or jump to what you need from the routing table.
      </p>

      <!-- Search -->
      <div class="relative max-w-md">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          type="search"
          id="doc-search"
          placeholder="Filter docs..."
          class="w-full pl-10 pr-4 py-2.5 text-sm bg-surface border border-border rounded-lg text-text placeholder-text-muted focus:outline-none focus:border-accent-dim transition-colors"
          autocomplete="off"
        />
      </div>
    </div>

    <div id="doc-no-results" class="hidden mb-8 text-text-muted text-sm">
      No docs match your search.
    </div>

    <!-- Reading Order -->
    <section class="mb-14 doc-section">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-6">
        Reading Order
      </h2>
      <div class="pl-4 border-l-2 border-border space-y-2 font-mono text-sm text-text-muted leading-relaxed">
        <p>
          <a href={`${base}docs/getting-started/`} class="text-text hover:text-accent no-underline font-semibold">Getting Started</a>
          <span class="text-text-muted"> -- first session, claims, session rhythm</span>
        </p>
        <div class="pl-6 space-y-2">
          <p>
            <a href={`${base}docs/skills/`} class="text-text hover:text-accent no-underline font-semibold">Skills Reference</a>
            <span class="text-text-muted"> -- command dictionary</span>
          </p>
          <div class="pl-6">
            <p>
              <a href={`${base}docs/workflows/`} class="text-text hover:text-accent no-underline font-semibold">Workflows</a>
              <span class="text-text-muted"> -- how commands compose</span>
            </p>
          </div>
          <p>
            <a href={`${base}docs/architecture/`} class="text-text hover:text-accent no-underline font-semibold">Architecture</a>
            <span class="text-text-muted"> -- why the system is shaped this way</span>
          </p>
          <p>
            <a href={`${base}docs/configuration/`} class="text-text hover:text-accent no-underline font-semibold">Configuration</a>
            <span class="text-text-muted"> -- how to tune it</span>
          </p>
        </div>
      </div>
    </section>

    <!-- Routing Table -->
    <section class="mb-14 doc-section">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-6">
        I need to...
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <tbody>
            {routes.map((route) => (
              <tr class="border-b border-border">
                <td class="py-2.5 pr-4 text-text-muted">{route.need}</td>
                <td class="py-2.5">
                  <a
                    href={`${base}docs/${route.slug}/`}
                    class="text-link hover:text-text no-underline font-medium"
                  >
                    {titleFromSlug(route.slug)}
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Three tiers as card grids -->
    {tiers.map((tier) => (
      <section class="mb-10 doc-tier-section">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-1">
          {tier.label}
        </h2>
        <p class="text-sm text-text-muted mb-4">{tier.description}</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {tier.slugs.map((slug) => (
            <a
              href={`${base}docs/${slug}/`}
              class="doc-card block p-5 rounded-lg border border-border bg-surface hover:border-accent-dim transition-colors no-underline group card-shadow card-shadow-hover"
              data-doc-slug={slug}
            >
              <div class="flex items-start justify-between gap-2 mb-2">
                <h3 class="font-display font-semibold text-text group-hover:text-accent transition-colors">
                  {titleFromSlug(slug)}
                </h3>
                {readingTime(slug) && (
                  <span class="text-xs text-text-muted whitespace-nowrap mt-0.5">
                    {readingTime(slug)}
                  </span>
                )}
              </div>
              {descFromSlug(slug) && (
                <p class="text-sm text-text-muted leading-relaxed line-clamp-2">
                  {descFromSlug(slug)}
                </p>
              )}
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <script define:vars={{ searchData }}>
    document.addEventListener("DOMContentLoaded", () => {
      const input = document.getElementById("doc-search");
      const noResults = document.getElementById("doc-no-results");
      if (!input || !noResults) return;

      const cards = document.querySelectorAll(".doc-card");
      const tierSections = document.querySelectorAll(".doc-tier-section");

      input.addEventListener("input", () => {
        const q = input.value.toLowerCase().trim();

        if (!q) {
          cards.forEach((c) => c.classList.remove("hidden"));
          tierSections.forEach((s) => s.classList.remove("hidden"));
          noResults.classList.add("hidden");
          return;
        }

        let visibleCount = 0;
        cards.forEach((card) => {
          const slug = card.dataset.docSlug;
          const entry = searchData.find((d) => d.slug === slug);
          const haystack = entry
            ? `${entry.title} ${entry.description}`.toLowerCase()
            : "";
          const match = haystack.includes(q);
          card.classList.toggle("hidden", !match);
          if (match) visibleCount++;
        });

        tierSections.forEach((section) => {
          const hasVisible = section.querySelector(".doc-card:not(.hidden)");
          section.classList.toggle("hidden", !hasVisible);
        });

        noResults.classList.toggle("hidden", visibleCount > 0);
      });
    });
  </script>
</Base>
